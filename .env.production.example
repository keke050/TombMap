# Public domain for HTTPS (point DNS A record to your server IP)
DOMAIN=combmap.example.com
#
# Email used for Let's Encrypt certificate issuance (Caddy)
CADDY_EMAIL=you@example.com

# Postgres (Docker)
POSTGRES_DB=combmap
POSTGRES_USER=combmap
POSTGRES_PASSWORD=change-me

# App secrets/config
NEXT_PUBLIC_AMAP_KEY=
NEXT_PUBLIC_AMAP_SECURITY=
AMAP_WEB_KEY=
SERPAPI_KEY=

# Optional: if you use an external managed Postgres, set DATABASE_URL
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

